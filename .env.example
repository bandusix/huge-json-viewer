# Anonymous usage analytics (GA4 Measurement Protocol). Optional.
# Copy to `.env.local` and fill in to enable analytics in a LOCAL build.
# In CI, set these as GitHub repo secrets GA_MEASUREMENT_ID / GA_API_SECRET instead.
# Leave unset and the app collects nothing (analytics is a no-op without both).
#
# GA4 Data stream → "Measurement ID" (looks like G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
# GA4 Admin → Data Streams → your stream → Measurement Protocol API secrets → Create
VITE_GA_API_SECRET=
