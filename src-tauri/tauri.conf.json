{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BigJSON",
  "version": "0.4.0",
  "identifier": "com.bigjson.viewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BigJSON",
        "width": 1180,
        "height": 780,
        "minWidth": 760,
        "minHeight": 480,
        "dragDropEnabled": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2018-2026, bandusix, All Rights Reserved",
    "shortDescription": "BigJSON — open and search multi-gigabyte JSON files",
    "longDescription": "BigJSON (formerly Huge JSON Viewer) — a fast native viewer for very large JSON files (multiple gigabytes). Memory-maps the file, builds a compact structural index, and renders a virtualized tree with instant search.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
